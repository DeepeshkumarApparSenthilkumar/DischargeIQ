# ── LLM (all agents use the same LLM_PROVIDER via get_llm_client / _get_client) ──
# anthropic | openrouter | openai | ollama
LLM_PROVIDER=anthropic

# Default when LLM_MODEL is unset: cheapest Anthropic tier (Haiku) for dev/testing.
# For Week 5 / higher-quality Claude eval, pin Sonnet (undated aliases can 404):
#   LLM_MODEL=claude-sonnet-4-20250514
#
# Default models when LLM_MODEL is unset:
#   anthropic  → claude-3-5-haiku-20241022
#   openrouter → openai/gpt-4o-mini
#   openai     → gpt-4o-mini
#   ollama     → llama3.2
# LLM_MODEL=

# API keys — set the key(s) for your LLM_PROVIDER (anthropic needs ANTHROPIC_API_KEY)
OPENROUTER_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Ollama base URL — only if LLM_PROVIDER=ollama and not on localhost
# OLLAMA_BASE_URL=http://localhost:11434/v1

# Neon PostgreSQL connection string (optional for core /analyze; required for history writes)
DATABASE_URL=
