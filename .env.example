# ── LLM (all five agents use the same LLM_PROVIDER via get_llm_client / _get_client) ──
# openrouter | openai | anthropic | ollama
LLM_PROVIDER=openrouter

# Required model override for Week 5 / Claude eval — undated aliases (e.g. claude-sonnet-4-6)
# can return 404 from the API. Pin the dated Sonnet ID:
#   LLM_PROVIDER=anthropic
#   LLM_MODEL=claude-sonnet-4-20250514
#
# Default models when LLM_MODEL is unset:
#   openrouter → openai/gpt-4o-mini
#   openai     → gpt-4o-mini
#   anthropic  → claude-sonnet-4-20250514
#   ollama     → llama3.2
# LLM_MODEL=

# API keys — set the key(s) for your LLM_PROVIDER (anthropic needs ANTHROPIC_API_KEY)
OPENROUTER_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Ollama base URL — only if LLM_PROVIDER=ollama and not on localhost
# OLLAMA_BASE_URL=http://localhost:11434/v1

# Neon PostgreSQL connection string (optional for core /analyze; required for history writes)
DATABASE_URL=
