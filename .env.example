# LLM provider: openrouter | openai | ollama  (default: openrouter)
LLM_PROVIDER=openrouter

# Optional model override — if not set, each provider uses its default:
#   openrouter → openai/gpt-oss-20b:free
#   openai     → gpt-4o-mini
#   ollama     → llama3.2
# LLM_MODEL=openai/gpt-oss-20b:free

# API keys — only the key matching your chosen LLM_PROVIDER is required
OPENROUTER_API_KEY=
OPENAI_API_KEY=

# Ollama base URL — only needed if LLM_PROVIDER=ollama and Ollama is not on localhost
# OLLAMA_BASE_URL=http://localhost:11434/v1

# Claude API — used by Agents 2-5 in Sprint 2
ANTHROPIC_API_KEY=

# Neon PostgreSQL connection string
DATABASE_URL=
