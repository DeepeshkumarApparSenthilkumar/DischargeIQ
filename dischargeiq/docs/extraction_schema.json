{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ExtractionOutput",
  "type": "object",
  "required": ["primary_diagnosis"],
  "properties": {
    "patient_name": { "type": ["string", "null"] },
    "discharge_date": { "type": ["string", "null"] },
    "primary_diagnosis": { "type": "string" },
    "secondary_diagnoses": { "type": "array", "items": { "type": "string" }, "default": [] },
    "procedures_performed": { "type": "array", "items": { "type": "string" }, "default": [] },
    "medications": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": { "type": "string" },
          "dose": { "type": ["string", "null"] },
          "frequency": { "type": ["string", "null"] },
          "duration": { "type": ["string", "null"] },
          "status": { "type": ["string", "null"] }
        }
      },
      "default": []
    },
    "follow_up_appointments": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "provider": { "type": ["string", "null"] },
          "specialty": { "type": ["string", "null"] },
          "date": { "type": ["string", "null"] },
          "reason": { "type": ["string", "null"] }
        }
      },
      "default": []
    },
    "activity_restrictions": { "type": "array", "items": { "type": "string" }, "default": [] },
    "dietary_restrictions": { "type": "array", "items": { "type": "string" }, "default": [] },
    "red_flag_symptoms": { "type": "array", "items": { "type": "string" }, "default": [] },
    "discharge_condition": { "type": ["string", "null"] },
    "extraction_warnings": { "type": "array", "items": { "type": "string" }, "default": [] }
  }
}
